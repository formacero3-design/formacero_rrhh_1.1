{
  "proyecto": "Formacero RRHH 1.1",
  "descripcion": "Sistema de Gestión de Recursos Humanos para Formacero SAS - Full Stack con React + Express + Supabase",
  "fecha_analisis": "2026-05-25",
  "stack_tecnologico": {
    "frontend": "React 19 + React Router 7 + Vite",
    "backend": "Node.js + Express 5 + Supabase",
    "base_datos": "Supabase (PostgreSQL)",
    "autenticacion": "JWT + bcrypt",
    "deployment": "Vercel",
    "email": "Nodemailer (Gmail SMTP)"
  },
  "estructura_general": {
    "backend_puerto": 3001,
    "frontend_puerto": 5173,
    "api_prefix": "/api"
  },
  "backend": {
    "servidor_principal": {
      "archivo": "backend/server.js",
      "proposito": "Punto de entrada principal del servidor Express con CORS, middlewares y rutas",
      "componentes_principales": [
        "Configuración de Express",
        "CORS dinámico (localhost, GitHub, Vercel)",
        "Middlewares globales (express.json, logging)",
        "Servir archivos estáticos (/uploads)",
        "Rutas principales",
        "Manejo de errores global"
      ],
      "dependencias": [
        "express ^5.2.1",
        "cors ^2.8.6",
        "dotenv ^17.4.0",
        "path",
        "fileURLToPath"
      ],
      "rutas_definidas": [
        "GET / - Health check",
        "GET /health - Health status",
        "GET /uploads/* - Archivos estáticos",
        "GET /api/uploads/* - Archivos estáticos alt",
        "POST /api/auth/* - Autenticación",
        "GET,POST,PUT,DELETE /api/empleados/* - CRUD empleados",
        "GET,POST,PUT,DELETE /api/reportes/* - CRUD reportes"
      ],
      "variables_entorno": [
        "SUPABASE_URL",
        "SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "JWT_SECRET",
        "FRONTEND_URL",
        "EMAIL_USER",
        "EMAIL_PASS",
        "EMAIL_FROM",
        "EMAIL_HOST",
        "EMAIL_PORT",
        "NODE_ENV"
      ],
      "comunicacion": "Importa y usa todas las rutas de auth, empleados y reportes"
    },
    "index": {
      "archivo": "backend/index.js",
      "proposito": "Configuración de dotenv",
      "componentes_principales": [
        "Carga de variables de entorno"
      ],
      "dependencias": ["dotenv"]
    },
    "db": {
      "archivo": "backend/db.js",
      "proposito": "Adaptador de base de datos que traduce SQL MySQL a Supabase",
      "componentes_principales": [
        "db.query() - Ejecuta queries SQL convertidas a Supabase",
        "Soporte SELECT/INSERT/UPDATE para empleados, exempleados, usuarios, reportes, documentos"
      ],
      "dependencias": [
        "@supabase/supabase-js ^2.104.0"
      ],
      "nota": "Este archivo está siendo gradualmente reemplazado por directivas Supabase en controladores"
    },
    "config_supabase": {
      "archivo": "backend/config/supabase.js",
      "proposito": "Inicialización del cliente Supabase con validación de env vars",
      "componentes_principales": [
        "Validación de SUPABASE_URL y llaves",
        "Creación de cliente Supabase",
        "Warnings para configuración incompleta"
      ],
      "dependencias": [
        "@supabase/supabase-js",
        "dotenv",
        "fs",
        "path"
      ],
      "configuracion_paths": [
        ".env (raíz)",
        "backend/.env (desarrollo)",
        "Vercel env vars (producción)"
      ]
    },
    "controller_auth": {
      "archivo": "backend/controllers/auth.controller.js",
      "proposito": "Lógica de autenticación: login, forgot-password, reset-password",
      "funciones_principales": {
        "login": {
          "descripcion": "Autentica usuario por correo/usuario y contraseña",
          "parametros": "{ usuario, correo, password }",
          "respuesta": "{ message, token, user }",
          "proceso": "Busca usuario → verifica bcrypt → genera JWT 8h → retorna foto"
        },
        "forgotPassword": {
          "descripcion": "Inicia proceso de recuperación de contraseña",
          "parametros": "{ correo }",
          "respuesta": "{ message } con email de reset enviado",
          "proceso": "Busca usuario → genera token reset → envía email con link"
        },
        "resetPassword": {
          "descripcion": "Establece nueva contraseña con token reset",
          "parametros": "{ token, nuevaPassword }",
          "respuesta": "{ message }",
          "proceso": "Valida token → hashea contraseña → actualiza usuario"
        }
      },
      "dependencias": [
        "@supabase/supabase-js",
        "bcrypt ^6.0.0",
        "jsonwebtoken ^9.0.3",
        "crypto",
        "nodemailer ^7.0.10"
      ],
      "integraciones": "Supabase, Email SMTP, JWT"
    },
    "controller_empleados": {
      "archivo": "backend/controllers/empleados.controller.js",
      "proposito": "CRUD completo de empleados, documentos, contactos de emergencia",
      "funciones_principales": {
        "getEmpleados": "Obtiene lista de todos los empleados con departamentos",
        "getEmpleadoById": "Obtiene empleado específico por ID",
        "createEmpleado": "Crea nuevo empleado con foto y documentos en Supabase Storage",
        "updateEmpleado": "Actualiza datos del empleado y foto",
        "deleteEmpleado": "Marca empleado como inactivo",
        "searchEmpleado": "Busca empleados por nombre, correo, cédula",
        "countEmpleados": "Retorna total de empleados activos",
        "getCumpleaneros": "Lista empleados con cumpleaños en mes actual",
        "getExEmpleados": "Lista empleados retirados/despedidos",
        "deleteExEmpleado": "Elimina ex-empleado del sistema",
        "getCertificadoEmpleado": "Genera certificado laboral",
        "createContactoEmergencia": "Crea contacto de emergencia para empleado",
        "updateContactoEmergencia": "Actualiza contacto de emergencia",
        "updateDocumento": "Actualiza documento subido",
        "deleteDocumento": "Elimina documento de empleado"
      },
      "dependencias": [
        "@supabase/supabase-js",
        "bcrypt ^6.0.0",
        "multer ^2.1.1"
      ],
      "integraciones": "Supabase Storage (bucket 'empleados'), Supabase DB"
    },
    "controller_reportes": {
      "archivo": "backend/controllers/reportes.controller.js",
      "proposito": "CRUD de reportes disciplinarios, decisiones y respuestas de empleados",
      "funciones_principales": {
        "createReporte": "Admin crea reporte para empleado(s)",
        "getReportes": "Obtiene reportes (filtrados si no es admin)",
        "updateReporte": "Admin actualiza estado y decisión",
        "deleteReporte": "Elimina reporte",
        "responderReporte": "Empleado responde reporte con comentario y/o archivo"
      },
      "campos_reporte": {
        "id": "int PK",
        "empleado_id": "int FK",
        "descripcion": "text",
        "fecha": "timestamp",
        "estado": "pending|resuelto",
        "decision": "text",
        "respuesta_empleado": "text",
        "archivo_excusa": "varchar",
        "fecha_respuesta": "timestamp"
      },
      "dependencias": [
        "@supabase/supabase-js",
        "multer ^2.1.1"
      ],
      "integraciones": "Supabase DB, File storage"
    },
    "routes_auth": {
      "archivo": "backend/routes/auth.routes.js",
      "proposito": "Define rutas de autenticación",
      "endpoints": {
        "POST /api/auth/login": "Autentica usuario",
        "GET /api/auth/test": "Verifica backend activo",
        "POST /api/auth/forgot-password": "Inicia recuperación de contraseña",
        "POST /api/auth/reset-password": "Completa reset de contraseña"
      },
      "middleware": "Ninguno (public routes)"
    },
    "routes_empleados": {
      "archivo": "backend/routes/empleados.routes.js",
      "proposito": "Define todas las rutas CRUD de empleados",
      "middleware": "verifyToken (global)",
      "endpoints": {
        "GET /api/empleados": "Obtiene todos los empleados",
        "GET /api/empleados/search": "Busca empleados",
        "GET /api/empleados/count": "Cuenta total de empleados",
        "GET /api/empleados/cumpleaneros": "Cumpleaños del mes",
        "GET /api/empleados/exempleados": "Ex-empleados",
        "GET /api/empleados/certificado/:id": "Genera certificado",
        "GET /api/empleados/:id": "Obtiene empleado específico",
        "POST /api/empleados": "Crea nuevo empleado (multipart: foto, documentos)",
        "PUT /api/empleados/:id": "Actualiza empleado (multipart: foto)",
        "DELETE /api/empleados/:id": "Elimina empleado",
        "POST /api/empleados/:id/documentos": "Sube documento",
        "POST /api/empleados/:id/contacto-emergencia": "Crea contacto emergencia",
        "PUT /api/empleados/:id/contacto-emergencia/:contactoId": "Actualiza contacto",
        "DELETE /api/empleados/exempleados/:id": "Elimina ex-empleado"
      }
    },
    "routes_reportes": {
      "archivo": "backend/routes/reportes.routes.js",
      "proposito": "Define rutas de reportes disciplinarios",
      "middleware": "verifyToken (global), requireAdmin (rutas de creación/edición)",
      "endpoints": {
        "GET /api/reportes": "Obtiene reportes (usuario ve solo los suyos)",
        "POST /api/reportes": "Crea reporte (admin only)",
        "PUT /api/reportes/:id": "Actualiza reporte (admin only)",
        "DELETE /api/reportes/:id": "Elimina reporte (admin only)",
        "POST /api/reportes/:id/responder": "Empleado responde reporte (multipart: archivo)"
      }
    },
    "middleware_auth": {
      "archivo": "backend/middlewares/auth.middleware.js",
      "proposito": "Verifica y valida JWT en todas las requests protegidas",
      "funciones_principales": {
        "verifyToken": "Extrae JWT del header Authorization, lo valida, agrega req.user"
      },
      "dependencias": ["jsonwebtoken ^9.0.3"],
      "uso": "Aplicado globalmente a rutas de empleados y reportes"
    },
    "middleware_roleauth": {
      "archivo": "backend/middlewares/roleAuth.js",
      "proposito": "Verifica rol de usuario (admin vs empleado)",
